{
  "expo": {
    "name": "Ultimate Golf Community",
    "slug": "ultimate-golf-community",
    "scheme": "ugcapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/ugc-app-icon.png",
    "splash": {
      "image": "./assets/ugc-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07140f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "deploymentTarget": "15.1",
      "bundleIdentifier": "com.ultimategolfcommunity.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "NSPhotoLibraryUsageDescription": "Ultimate Golf Community uses your photo library so you can choose a profile photo.",
        "NSCameraUsageDescription": "Ultimate Golf Community uses the camera so you can take a profile photo.",
        "NSLocationWhenInUseUsageDescription": "Ultimate Golf Community uses your location to show golf weather near you."
      },
      "associatedDomains": [
        "applinks:www.ultimategolfcommunity.com"
      ]
    },
    "android": {
      "package": "com.ultimategolfcommunity.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/ugc-android-foreground.png",
        "backgroundColor": "#07140f"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "www.ultimategolfcommunity.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-apple-authentication",
      "expo-notifications",
      "expo-image-picker",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "cc8e613b-fa1d-4f05-9d59-e4b276c74928"
      }
    },
    "owner": "ultimategolfcommunity"
  }
}
